// PROCESO PARA SABER SI EL NUMERO QUE NOS DAN ES POSITIVO
PROCESO PROCEDIMIENTO_PARA_SABER_SI_EL_NUMERO_QUE_NOS_DEN_ES_POSITIVO
	ESCRIBIR "BIENVENIDO, TE AYUDAREMOS A SABER SI EL NUMERO QUE NOS DAN ES POSITIVO"
	ESCRIBIR "INGRESE EL NUMERO"
	LEER NUMERO
	SI NUMERO >=0 ENTONCES 
		ESCRIBIR "EL NUMERO ES POSITIVO"
	SiNo
		Escribir "EL NUMERO ES NEGATIVO"
	FINSI
FINPROCESO
