// PROCESO PARA SABER SI UNA BODEGA CUENTA CON SUFICIENTES PIEZAS
PROCESO PROCEDIMIENTO_PARA_SABER_SI_HAY_SUFICIETES_PIEZAS_EN_LA_BODEGA
	ESCRIBIR "BIENVENIDO, TE AYUDAREMOS A SABERSI CUENTAS CON SUFICIENTES PIEZAS EN LA BODEGA"
	ESCRIBIR "INGRESE LA CANTIDAD DE PIEZAS DISPONIBLES"
	LEER PIEZAS
	SI PIEZAS <=5 ENTONCES 
		ESCRIBIR "SOLICITAR PEDIDO URGENTE AL PROVEEDOR"
	SiNo
		Escribir "HAY SUFICIENTES PIEZAS"
	FINSI
FINPROCESO
