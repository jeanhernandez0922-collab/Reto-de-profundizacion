// PROCESO PARA SABER SI ALCANZO LA COMPETENCIA QUE PIDEN EN EL COLEGIO
PROCESO PROCEDIMIENTO_PARA_SABER_SI_ALCANZO_LA_COMPETENCIA
	ESCRIBIR "BIENVENIDO, TE AYUDAREMOS A SABER SI ALCANZASTES LA COMPETENCIA"
	ESCRIBIR "INGRESE SU NOTA"
	LEER NOTA
	SI NOTA >=3.5 ENTONCES 
		ESCRIBIR "COMPETENCIA ALCANZADA"
	SiNo
		Escribir "COMPETENCIA NO ALCANZA"
	FINSI
FINPROCESO
